{
  "description": "Default schema-aware CD-ViT manifest training run.",
  "manifest": "runs/landmarks/cdvit_fs68_hard/hard_negative_mix/manifest.json",
  "run_name": "train_cdvit_manifest",
  "training": {
    "epoch": 500,
    "batch_size": 16,
    "heatmap_size": 32,
    "lr": 0.0001,
    "nproc_per_node": 2,
    "train_data_name": "FS68Manifest"
  },
  "runtime": {
    "num_workers": 12,
    "preload": 0,
    "persistent_workers": true,
    "pin_memory": true,
    "prefetch_factor": 2
  },
  "eval": {
    "eval_batch_size": 8,
    "eval_every": 5,
    "full_eval_every": 25,
    "eval_ema_every": 5,
    "eval_ema_scope": "full-only",
    "eval_max_samples": 2048,
    "eval_progress": false,
    "eval_slice_reports_every": 25
  },
  "checkpoint": {
    "save_last_checkpoint": true,
    "save_legacy_epoch_state_dict": false
  }
}
